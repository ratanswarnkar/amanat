{
  "expo": {
    "name": "Amanat App",
    "slug": "amanat-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "amanatapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.ratansoni.amanat",
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2456B6",
          "defaultChannel": "default"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ce2c89c4-ed27-4826-8b95-3366910c173d"
      }
    }
  }
}
